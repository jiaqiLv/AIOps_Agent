# Model Provider Selection (deepseek, openai, anthropic)
LLM_PROVIDER=deepseek

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Anthropic API (optional)
ANTHROPIC_API_KEY=

# LLM Default Settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=aiops-diagnose-agent

# LangGraph
LANGGRAPH_DEBUG=true
# 服务在服务器上监听 2024：langgraph dev --host 0.0.0.0 --port 2024
# 若做了端口映射（服务器 2024 -> 局域网 32025），此处填本机访问用的外网地址
LANGGRAPH_PUBLIC_BASE_URL=http://192.168.199.5:32025
GRAPH_OUTPUT_DIR=outputs/graphs

# MCP Tools (reserved for future implementation)
RCD_MCP_SERVER_URL=http://localhost:8001
PC_MCP_SERVER_URL=http://localhost:8002
